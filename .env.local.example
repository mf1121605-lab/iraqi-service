NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Absolute base URL of this deployment, used to build gateway redirect/
# return URLs (e.g. https://your-domain.com, or http://localhost:3000 in dev).
NEXT_PUBLIC_APP_URL=

# --- ZainCash (بوابة دفع زين كاش) ---
# Classic Instant Online Payment (IOP) product. Obtain these from your
# ZainCash merchant onboarding; confirm you're on this product and not
# their newer OAuth2-based v2 gateway, which uses different credentials
# and a different flow entirely.
ZAINCASH_MERCHANT_ID=
ZAINCASH_MSISDN=
ZAINCASH_SECRET=
# "test" or "production"
ZAINCASH_MODE=test

# --- Al-Rafidain Mastercard (بوابة ماستر كارد مصرف الرافدين) ---
# No public API is documented for Al-Rafidain directly; this integration
# is built against the Mastercard Payment Gateway Services (MPGS) Hosted
# Checkout contract, which many banks license and rebrand. Confirm with
# Al-Rafidain's merchant integration team whether this is in fact their
# underlying gateway, and get the bank-hosted base URL / API version from
# them — do not guess a URL here.
RAFIDAIN_MERCHANT_ID=
RAFIDAIN_API_PASSWORD=
# e.g. https://<bank-hosted-domain>/api/rest/version/<version>
RAFIDAIN_API_BASE_URL=
# Loaded client-side to render the hosted payment page; must come from the
# same gateway host as RAFIDAIN_API_BASE_URL above.
NEXT_PUBLIC_RAFIDAIN_CHECKOUT_JS_URL=
