NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Absolute base URL of this deployment, used to build gateway redirect/
# return URLs (e.g. https://your-domain.com, or http://localhost:3000 in dev).
NEXT_PUBLIC_APP_URL=

# --- ZainCash (بوابة دفع زين كاش) ---
ZAINCASH_MERCHANT_ID=
ZAINCASH_MSISDN=
ZAINCASH_SECRET=
# "test" or "production"
ZAINCASH_MODE=test

# --- Al-Rafidain Mastercard (بوابة ماستر كارد مصرف الرافدين) ---
RAFIDAIN_MERCHANT_ID=
RAFIDAIN_API_PASSWORD=
# e.g. https://<bank-hosted-domain>/api/rest/version/<version>
RAFIDAIN_API_BASE_URL=
# Loaded client-side to render the hosted payment page; must come from the
# same gateway host as RAFIDAIN_API_BASE_URL above.
NEXT_PUBLIC_RAFIDAIN_CHECKOUT_JS_URL=

# --- Web Push (نظام الإشعارات الفورية) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Required by the Web Push spec so push services can contact you about
# delivery issues — a mailto: address or an https:// URL for this project.
VAPID_SUBJECT=mailto:admin@example.com

# Shared secret between the notifications-table dispatch trigger and
# /api/push/dispatch — generate any long random string. Set the matching
# value in the `app_config` table via the Supabase SQL editor after
# deploying (see the push_notifications migration for the exact command).
PUSH_DISPATCH_SECRET=
